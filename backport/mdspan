#pragma once

// Backport wrapper for <mdspan>.
//
// Strategy:
//  1. Include the real standard library <mdspan> via include_next (or the MSVC
//     path macro). If the toolchain has no <mdspan> this silently skips it; the
//     submdspan backport will not be injected either in that case (because
//     __cpp_lib_mdspan will remain undefined and the guard below fails).
//  2. If __cpp_lib_submdspan is not yet defined (true for all known toolchains
//     as of March 2026), inject the Forge submdspan backport.

#if defined(_MSC_VER)
#  ifdef FORGE_MSVC_MDSPAN_HEADER
#    include FORGE_MSVC_MDSPAN_HEADER
#  endif
#elif defined(__has_include_next)
#  if __has_include_next(<mdspan>)
#    include_next <mdspan>
#  endif
#endif

// Inject submdspan backport only when:
//  - The standard <mdspan> was found (__cpp_lib_mdspan is defined)
//  - The native submdspan is not yet present
#if defined(__cpp_lib_mdspan) && !defined(__cpp_lib_submdspan)
#  include "cpp26/submdspan.hpp"
#endif
