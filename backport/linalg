#pragma once

// <linalg> is a new header in C++26 — it did not exist before, so we cannot
// use include_next to get the standard version. Instead we check for native
// support via __cpp_lib_linalg and only inject the backport when absent.

#if defined(_MSC_VER) && defined(FORGE_MSVC_LINALG_HEADER)
#include FORGE_MSVC_LINALG_HEADER
#elif defined(__has_include_next)
#if __has_include_next(<linalg>)
#include_next <linalg>
#endif
#endif

// Inject backport if native linalg is not available.
#if !defined(__cpp_lib_linalg) || (__cpp_lib_linalg < 202311L)
#include "cpp26/linalg.hpp"
#endif
